prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
sharedlibdir=${exec_prefix}/lib
includedir=${exec_prefix}/include

Name: zlib
Description: zlib compression library
Version: 1.3.2
License: Zlib

Requires:
Libs: "-L${libdir}" "-L${sharedlibdir}" -lz
Cflags: "-I${includedir}"

